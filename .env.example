# Google Custom Search API (for finding companies)
# Get API key: https://console.cloud.google.com/apis/credentials
# Create a Custom Search Engine: https://programmablesearchengine.google.com/
# Set it to search the entire web
# NOTE: Works without these keys too (falls back to direct scraping)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Google Places API for finding well-reviewed businesses with no website listed
# You can reuse GOOGLE_SEARCH_API_KEY if the same Google Cloud key has Places API enabled.
GOOGLE_PLACES_API_KEY=
ENABLE_NO_WEBSITE_PLACES=true
TARGET_LOCATIONS=Houston TX
MIN_GOOGLE_RATING=4.2
MIN_GOOGLE_REVIEW_COUNT=25
PLACES_RESULTS_PER_QUERY=8

# SMTP Settings for sending outreach emails
# SendGrid: SMTP_USERNAME must be exactly "apikey" and SMTP_PASSWORD is your SendGrid API key.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_EMAIL=verified_sender@example.com
SMTP_PASSWORD=your_sendgrid_api_key_here
DISABLE_SENDGRID_CLICK_TRACKING=true

# Human-paced sending controls
# Live sends are capped across runs by leads_output/email_send_history.csv.
MAX_EMAILS_PER_DAY=25
EMAIL_DELAY_MIN_SECONDS=600
EMAIL_DELAY_MAX_SECONDS=2700
SKIP_PREVIOUSLY_EMAILED=true

# Leave this false to avoid emailing unverified guessed addresses like info@example.com.
USE_GUESSED_EMAILS=false

# Scheduled background outreach
# Windows Task Scheduler wakes the worker during this window; the worker exits after each run.
SCHEDULED_OUTREACH_ENABLED=true
SCHEDULED_DAILY_EMAIL_LIMIT=25
SCHEDULED_MAX_EMAILS_PER_RUN=2
SCHEDULED_INTRA_RUN_DELAY_SECONDS=30
SCHEDULED_TASK_INTERVAL_MINUTES=30
BUSINESS_DAYS=MON,TUE,WED,THU,FRI
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00
SCHEDULED_AUTO_REFILL_QUEUE=true
SCHEDULED_REFILL_MIN_QUEUE=10
SCHEDULED_REFILL_LIMIT=50
REPORT_RECIPIENTS=lucas@iqventoryllc.com,amoreno@iqventoryllc.com
SCHEDULED_TARGET_INDUSTRIES=commercial concrete contractor,ready mix concrete,asphalt contractor,excavation contractor,demolition contractor,dump truck service,sand and gravel supplier,metal fabricator,welding shop,machine shop,industrial equipment repair,commercial roofing contractor

# Your business info (used in email templates)
YOUR_NAME=Your Name
YOUR_COMPANY=Bunz Webby
YOUR_PHONE=555-555-5555
YOUR_WEBSITE=https://yourwebsite.com
PAST_PROJECT_NAME=Gulf States Materials
PAST_PROJECT_URL=https://gulfstatesmaterials.com
PAST_PROJECT_DISPLAY_URL=gulfstatesmaterials.com

# Optional: Hunter.io API key for finding owner emails (25 free/month)
# Get one at: https://hunter.io/api
HUNTER_API_KEY=

# Optional: PageSpeed Insights API key (works without it, just slower)
PAGESPEED_API_KEY=
