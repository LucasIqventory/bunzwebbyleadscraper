# Google Custom Search API (for finding companies)
# Get API key: https://console.cloud.google.com/apis/credentials
# Create a Custom Search Engine: https://programmablesearchengine.google.com/
# Set it to search the entire web
# NOTE: Works without these keys too (falls back to direct scraping)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# SMTP Settings for sending outreach emails
# For Gmail: enable 2FA then create an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Your business info (used in email templates)
YOUR_NAME=Your Name
YOUR_COMPANY=Bunz Webby
YOUR_PHONE=555-555-5555
YOUR_WEBSITE=https://yourwebsite.com

# Optional: Hunter.io API key for finding owner emails (25 free/month)
# Get one at: https://hunter.io/api
HUNTER_API_KEY=

# Optional: PageSpeed Insights API key (works without it, just slower)
PAGESPEED_API_KEY=
